---
import Layout from "../layouts/Layout.astro";
import projects from "../data/projects.json";

const statusClass: Record<string, string> = {
  PUBLISHED: "badge-published",
  RESEARCH: "badge-research",
  ACTIVE: "badge-active",
  STEALTH: "badge-stealth",
  COMPLETED: "badge-completed",
};
---

<Layout title="Edward Lue Chee Lip">

  <!-- ═══════════ HERO ═══════════ -->
  <section class="relative isolate min-h-screen flex items-center justify-center px-6 overflow-hidden">
    <!-- CSS grid background -->
    <div class="hero-grid" aria-hidden="true"></div>

    <!-- Scan line -->
    <div class="hero-scan"></div>

    <!-- Top glow -->
    <div class="hero-glow"></div>

    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <h1 class="font-mono font-bold text-6xl sm:text-7xl md:text-[5.5rem] tracking-tight text-white mb-6 fade-up">
        Edward
      </h1>
      <p class="font-mono text-xs sm:text-sm text-accent tracking-[0.25em] uppercase mb-10 fade-up stagger-1">
        AI Safety Researcher&ensp;·&ensp;Systems Builder&ensp;·&ensp;AAAI 2026 First Author
      </p>
      <p class="text-[#6a6a80] text-base sm:text-lg leading-relaxed max-w-xl mx-auto mb-12 fade-up stagger-2">
        I build systems at the edge of what AI can safely do. Self-taught. Left
        fermentation science to pursue AI safety full-time. Based in Trinidad and
        Tobago, open to relocation.
      </p>

      <!-- Links row -->
      <div class="flex flex-wrap items-center justify-center gap-5 sm:gap-7 mb-10 fade-up stagger-3">
        <a href="https://github.com/edward-lcl" target="_blank" rel="noopener" class="accent-link font-mono text-sm flex items-center gap-2">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a href="https://arxiv.org/abs/2512.14745" target="_blank" rel="noopener" class="accent-link font-mono text-sm flex items-center gap-2">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          arXiv
        </a>
        <a href="https://linkedin.com/in/edward-lue-chee-lip" target="_blank" rel="noopener" class="accent-link font-mono text-sm flex items-center gap-2">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a href="https://x.com/eluecheelip" target="_blank" rel="noopener" class="accent-link font-mono text-sm flex items-center gap-2">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          X
        </a>
      </div>

      <!-- Scroll CTA -->
      <a href="#work" class="inline-block font-mono text-[11px] text-[#3d3d50] tracking-[0.3em] uppercase hover:text-accent transition-colors duration-300 fade-up stagger-4">
        View Work ↓
      </a>
    </div>
  </section>

  <!-- ═══════════ WORK / PROJECT TIMELINE ═══════════ -->
  <section id="work" class="max-w-3xl mx-auto px-6 py-16">
    <h2 class="font-mono text-xl font-bold text-white mb-10 tracking-tight section-heading reveal">
      Work
    </h2>

    <div class="relative pl-8">
      <div class="timeline-line"></div>

      {projects.map((project, i) => {
        const isClickable = project.url && project.status !== "STEALTH";
        const cardClasses = `relative mb-8 last:mb-0 reveal timeline-card ${project.featured ? 'timeline-card-featured' : ''}`;
        const cardContent = (
          <>
            <div class="timeline-dot"></div>
            <div class="flex items-baseline gap-3 mb-2 flex-wrap">
              <span class={`font-mono text-base font-medium ${project.status === "STEALTH" ? "text-stealth" : "text-white"}`}>
                {project.name}
              </span>
              <span class="font-mono text-xs text-[#3d3d50]">{project.year}</span>
              <span class={`font-mono text-[10px] uppercase tracking-wider border px-2 py-0.5 rounded-full ${statusClass[project.status] || ""}`}>
                {project.status}
              </span>
              {isClickable && (
                <span class="ml-auto text-[#3a3a4a] group-hover:text-accent text-xs transition-colors">↗</span>
              )}
            </div>

            {project.status !== "STEALTH" ? (
              <p class="text-[#6a6a80] text-sm leading-relaxed mb-3 max-w-2xl">
                {project.description}
              </p>
            ) : (
              <p class="text-[#3d3d50] text-sm italic mt-1 mb-3">Details confidential.</p>
            )}

            <div class="flex flex-wrap gap-x-3 gap-y-1">
              {project.tags.map((tag: string) => (
                <span class="font-mono text-[10px] text-[#4a4a5a] uppercase tracking-wider">
                  {tag}
                </span>
              ))}
            </div>
          </>
        );

        return isClickable ? (
          <a href={project.url} target="_blank" rel="noopener"
             class={`block group ${cardClasses}`}
             data-delay={Math.min(i * 40, 100)}>
            {cardContent}
          </a>
        ) : (
          <div class={cardClasses}
               data-delay={Math.min(i * 40, 100)}>
            {cardContent}
          </div>
        );
      })}
    </div>
  </section>

  <!-- ═══════════ CURRENTLY BUILDING ═══════════ -->
  <section class="max-w-3xl mx-auto px-6 py-16 section-divider">
    <h2 class="font-mono text-xl font-bold text-white mb-8 tracking-tight section-heading reveal">
      Now
    </h2>
    <p class="text-[#6a6a80] text-base leading-relaxed max-w-2xl reveal">
      Currently: Scaling deception signature research toward Anthropic Fellows
      Program (May/July 2026). Exploring side-channel calibration for production
      agent monitoring.
    </p>
  </section>

  <!-- ═══════════ ABOUT ═══════════ -->
  <section class="max-w-3xl mx-auto px-6 py-16 section-divider">
    <h2 class="font-mono text-xl font-bold text-white mb-8 tracking-tight section-heading reveal">
      About
    </h2>
    <p class="text-[#6a6a80] text-base leading-relaxed max-w-2xl mb-10 reveal">
      I started in fermentation science at Colorado State University, then took a
      leave to pursue AI safety research full-time. Self-taught through AI-first
      workflows and rapid iteration. First author of Factor(UT), accepted at AAAI
      2026 TrustAgent Workshop. I build safety tooling for frontier-scale agentic
      systems — adversarial evaluation, deception detection, monitoring.
    </p>
    <div class="flex flex-wrap gap-6 reveal">
      <a href="https://github.com/edward-lcl" target="_blank" rel="noopener" class="accent-link font-mono text-sm">GitHub</a>
      <a href="https://arxiv.org/abs/2512.14745" target="_blank" rel="noopener" class="accent-link font-mono text-sm">arXiv</a>
      <a href="https://linkedin.com/in/edward-lue-chee-lip" target="_blank" rel="noopener" class="accent-link font-mono text-sm">LinkedIn</a>
    </div>
  </section>

  <!-- ═══════════ FOOTER ═══════════ -->
  <footer class="max-w-3xl mx-auto px-6 py-14 section-divider">
    <p class="font-mono text-[11px] text-[#3d3d50] text-center tracking-wide">
      Edward Lue Chee Lip&ensp;·&ensp;eluecheelip@gmail.com&ensp;·&ensp;Built with Astro
    </p>
  </footer>

</Layout>

<!-- Scroll-triggered reveal animation -->
<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = el.dataset.delay;
          if (delay) {
            setTimeout(() => el.classList.add("visible"), parseInt(delay));
          } else {
            el.classList.add("visible");
          }
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px 0px 0px" }
  );

  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>
